# ─────────────────────────────────────────────────────────────
# .env.example — Plantilla para configurar un nuevo cliente.
# Copia este archivo a .env y completa los valores.
# El archivo .env NO debe subirse a Git.
# ─────────────────────────────────────────────────────────────

# URL del servidor Frappe/ERPNext
VITE_FRAPPE_URL="http://localhost:8000"

# ── Identidad visual del negocio ──────────────────────────────
VITE_EMPRESA_NOMBRE=Nombre del Negocio
VITE_EMPRESA_SUBTITULO=Giro del Negocio
VITE_EMPRESA_NOMBRE_FULL=NOMBRE DEL NEGOCIO EN MAYUSCULAS
VITE_EMPRESA_DIRECCION=DIRECCION DE LA SUCURSAL PRINCIPAL
VITE_EMPRESA_TELEFONO=0000000000
VITE_EMPRESA_WEB=www.ejemplo.com
VITE_EMPRESA_LOGO=/logo.png

# ── ERPNext / Frappe ─────────────────────────────────────────
# VITE_ERP_COMPANY debe coincidir EXACTO con el nombre de la empresa en ERPNext
VITE_ERP_COMPANY=Nombre Empresa ERPNext
VITE_BODEGA_CENTRAL=NOMBRE DEL ALMACEN CENTRAL
VITE_DEFAULT_CUSTOMER=Público en General
VITE_POS_PROFILE_DEFAULT=Nombre del POS Profile
# Nombre del módulo Python en apps/frappe (ej: gestion_panaderia, mi_app)
VITE_FRAPPE_APP=nombre_del_modulo

# ── Sucursales (separadas por coma) ──────────────────────────
VITE_SUCURSALES=Sucursal 1,Sucursal 2,Sucursal 3
